{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Pi-hole DNS Sinkhole Helm Chart Values",
  "description": "Values for the Pi-hole Helm chart - network-wide ad blocking via DNS filtering",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": {
      "type": "string",
      "description": "Override the chart name used in resource names",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "description": "Override the full release name used in resource names",
      "default": ""
    },
    "commonLabels": {
      "type": "object",
      "description": "Labels added to every resource created by this chart"
    },
    "image": {
      "type": "object",
      "description": "Container image configuration",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "description": "Container image repository",
          "default": "docker.io/pihole/pihole"
        },
        "tag": {
          "type": "string",
          "description": "Container image tag",
          "default": "2026.05.0"
        },
        "pullPolicy": {
          "type": "string",
          "description": "Image pull policy",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "description": "Image pull secrets for private registries",
      "items": {
        "type": "object"
      }
    },
    "pihole": {
      "type": "object",
      "description": "Pi-hole application configuration",
      "additionalProperties": false,
      "properties": {
        "timezone": {
          "type": "string",
          "description": "Timezone for logs and scheduled tasks",
          "default": "UTC"
        },
        "upstreamDns": {
          "type": "string",
          "description": "Upstream DNS servers (semicolon-delimited). When unbound sidecar is enabled, this is overridden to 127.0.0.1#5335.",
          "default": "8.8.8.8;8.8.4.4"
        },
        "listeningMode": {
          "type": "string",
          "description": "DNS listening mode",
          "enum": ["LOCAL", "ALL", "SINGLE", "BIND"],
          "default": "ALL"
        },
        "dnssec": {
          "type": "boolean",
          "description": "Enable DNSSEC validation",
          "default": false
        },
        "ftl": {
          "type": "object",
          "description": "FTL advanced configuration",
          "additionalProperties": false,
          "properties": {
            "cacheSize": {
              "type": "integer",
              "description": "DNS cache size",
              "default": 10000
            },
            "privacyLevel": {
              "type": "integer",
              "description": "Privacy level (0-3)",
              "minimum": 0,
              "maximum": 3,
              "default": 0
            },
            "cnameInspection": {
              "type": "boolean",
              "description": "Block CNAME-cloaked trackers",
              "default": true
            },
            "rateLimit": {
              "type": "integer",
              "description": "Rate limiting query count per client; set to 0 to disable rate limiting",
              "minimum": 0,
              "default": 1000
            },
            "rateLimitInterval": {
              "type": "integer",
              "description": "Rate limiting interval in seconds",
              "minimum": 0,
              "default": 60
            },
            "blockAAAA": {
              "type": "boolean",
              "description": "Block AAAA queries on A-only networks",
              "default": false
            },
            "queryLogging": {
              "type": "boolean",
              "description": "Query logging",
              "default": true
            },
            "useDatabase": {
              "type": "boolean",
              "description": "Use database for queries (required for long-term stats)",
              "default": true
            }
          }
        },
        "extraEnv": {
          "type": "array",
          "description": "Additional environment variables for the Pi-hole container",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "admin": {
      "type": "object",
      "description": "Web admin configuration",
      "additionalProperties": false,
      "properties": {
        "password": {
          "type": "string",
          "description": "Web admin password (auto-generated if empty and no existingSecret)",
          "default": ""
        },
        "existingSecret": {
          "type": "string",
          "description": "Use an existing secret for the admin password",
          "default": ""
        },
        "existingSecretKey": {
          "type": "string",
          "description": "Key in the existing secret that contains the admin password",
          "default": "password"
        }
      }
    },
    "dns": {
      "type": "object",
      "description": "DNS records and blocklists configuration",
      "additionalProperties": false,
      "properties": {
        "preset": {
          "type": "string",
          "description": "Blocklist preset",
          "enum": ["none", "basic", "balanced", "aggressive", "gaming-friendly"],
          "default": "none"
        },
        "adlists": {
          "type": "array",
          "description": "Custom blocklist URLs (added to preset)",
          "items": {
            "type": "string"
          }
        },
        "whitelistPresets": {
          "type": "object",
          "description": "Automatic whitelist presets for common services",
          "additionalProperties": false,
          "properties": {
            "microsoft": {
              "type": "boolean",
              "description": "Whitelist Microsoft services",
              "default": false
            },
            "apple": {
              "type": "boolean",
              "description": "Whitelist Apple services",
              "default": false
            },
            "google": {
              "type": "boolean",
              "description": "Whitelist Google services",
              "default": false
            },
            "gaming": {
              "type": "boolean",
              "description": "Whitelist gaming platforms",
              "default": false
            },
            "smartHome": {
              "type": "boolean",
              "description": "Whitelist smart home devices",
              "default": false
            }
          }
        },
        "whitelist": {
          "type": "array",
          "description": "Manual whitelisted domains (added to presets)",
          "items": {
            "type": "string"
          }
        },
        "blacklist": {
          "type": "array",
          "description": "Blacklisted domains (exact matches)",
          "items": {
            "type": "string"
          }
        },
        "regex": {
          "type": "array",
          "description": "Regex filters for blocking (advanced)",
          "items": {
            "type": "string"
          }
        },
        "conditionalForwarding": {
          "type": "object",
          "description": "Conditional forwarding for local domains",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable conditional forwarding",
              "default": false
            },
            "domain": {
              "type": "string",
              "description": "Local network domain",
              "default": ""
            },
            "network": {
              "type": "string",
              "description": "Local network CIDR",
              "default": ""
            },
            "router": {
              "type": "string",
              "description": "Router/DNS server IP for reverse lookups",
              "default": ""
            },
            "customRules": {
              "type": "array",
              "description": "Additional conditional forwarding rules",
              "items": {
                "type": "object",
                "properties": {
                  "domain": {
                    "type": "string"
                  },
                  "server": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "customRecords": {
          "type": "array",
          "description": "Custom local DNS A records (each entry: \"IP HOSTNAME\")",
          "items": {
            "type": "string"
          }
        },
        "cnameRecords": {
          "type": "array",
          "description": "Custom CNAME records (dnsmasq format)",
          "items": {
            "type": "string"
          }
        },
        "customDnsmasq": {
          "type": "array",
          "description": "Custom dnsmasq configuration lines",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "persistence": {
      "type": "object",
      "description": "Persistence configuration for /etc/pihole",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable persistent storage for /etc/pihole",
          "default": true
        },
        "storageClass": {
          "type": "string",
          "description": "Storage class (leave empty for cluster default)",
          "default": ""
        },
        "accessMode": {
          "type": "string",
          "description": "Access mode for the PVC",
          "default": "ReadWriteOnce"
        },
        "size": {
          "type": "string",
          "description": "Size of the persistent volume",
          "default": "1Gi"
        },
        "existingClaim": {
          "type": "string",
          "description": "Use an existing PVC instead of creating one",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the PVC"
        }
      }
    },
    "gravity": {
      "type": "object",
      "description": "Gravity database initialization",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable automated gravity database initialization",
          "default": true
        },
        "updateOnInit": {
          "type": "boolean",
          "description": "Run pihole -g after populating database",
          "default": true
        },
        "image": {
          "type": "object",
          "description": "Init container image configuration",
          "properties": {
            "repository": {
              "type": "string",
              "default": "docker.io/library/alpine"
            },
            "tag": {
              "type": "string",
              "default": "3.23"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "resources": {
          "type": "object",
          "description": "Resources for the init container"
        },
        "updateResources": {
          "type": "object",
          "description": "Resources for the gravity update init container"
        }
      }
    },
    "backup": {
      "type": "object",
      "description": "Automated S3 backups",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable automated backups to S3",
          "default": false
        },
        "schedule": {
          "type": "string",
          "description": "Backup schedule (cron format)",
          "default": "0 3 * * *"
        },
        "backoffLimit": {
          "type": "integer",
          "default": 1
        },
        "successfulJobsHistoryLimit": {
          "type": "integer",
          "default": 3
        },
        "failedJobsHistoryLimit": {
          "type": "integer",
          "default": 1
        },
        "concurrencyPolicy": {
          "type": "string",
          "enum": ["Forbid", "Allow", "Replace"],
          "default": "Forbid"
        },
        "include": {
          "type": "object",
          "properties": {
            "gravity": {
              "type": "boolean",
              "default": true
            },
            "customDns": {
              "type": "boolean",
              "default": true
            },
            "dnsmasq": {
              "type": "boolean",
              "default": true
            }
          }
        },
        "images": {
          "type": "object",
          "properties": {
            "utility": {
              "type": "object"
            },
            "uploader": {
              "type": "object"
            }
          }
        },
        "resources": {
          "type": "object"
        },
        "s3": {
          "type": "object",
          "properties": {
            "endpoint": {
              "type": "string"
            },
            "bucket": {
              "type": "string"
            },
            "prefix": {
              "type": "string",
              "default": "pihole"
            },
            "existingSecret": {
              "type": "string"
            },
            "accessKey": {
              "type": "string"
            },
            "secretKey": {
              "type": "string"
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "description": "CPU and memory requests/limits for the Pi-hole container"
    },
    "hostNetwork": {
      "type": "boolean",
      "description": "Use the host network for the main Pi-hole pod",
      "default": false
    },
    "dnsPolicy": {
      "type": "string",
      "description": "Pod DNS policy. Defaults to ClusterFirstWithHostNet when hostNetwork is enabled.",
      "enum": ["", "ClusterFirstWithHostNet", "ClusterFirst", "Default", "None"],
      "default": ""
    },
    "podSecurityContext": {
      "type": "object",
      "description": "Pod-level security context"
    },
    "securityContext": {
      "type": "object",
      "description": "Container-level security context"
    },
    "startupProbe": {
      "type": "object",
      "description": "Startup probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable startup probe",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer"
        },
        "periodSeconds": {
          "type": "integer"
        },
        "timeoutSeconds": {
          "type": "integer"
        },
        "failureThreshold": {
          "type": "integer"
        }
      }
    },
    "livenessProbe": {
      "type": "object",
      "description": "Liveness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable liveness probe",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer"
        },
        "periodSeconds": {
          "type": "integer"
        },
        "timeoutSeconds": {
          "type": "integer"
        },
        "failureThreshold": {
          "type": "integer"
        }
      }
    },
    "readinessProbe": {
      "type": "object",
      "description": "Readiness probe configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable readiness probe",
          "default": true
        },
        "initialDelaySeconds": {
          "type": "integer"
        },
        "periodSeconds": {
          "type": "integer"
        },
        "timeoutSeconds": {
          "type": "integer"
        },
        "failureThreshold": {
          "type": "integer"
        }
      }
    },
    "serviceDns": {
      "type": "object",
      "description": "DNS service configuration",
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for DNS",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "LoadBalancer"
        },
        "port": {
          "type": "integer",
          "description": "DNS port",
          "default": 53
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the DNS service"
        },
        "externalTrafficPolicy": {
          "type": "string",
          "description": "External traffic policy (set to Local for client IP preservation)"
        },
        "loadBalancerIP": {
          "type": "string",
          "description": "Load balancer IP (set a fixed IP for DNS stability)"
        },
        "ipFamilyPolicy": {
          "type": ["string", "null"],
          "description": "Dual-stack ipFamilyPolicy (GR-058)",
          "enum": [null, "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Dual-stack ipFamilies (GR-058)",
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] },
          "maxItems": 2
        }
      }
    },
    "serviceWeb": {
      "type": "object",
      "description": "Web admin service configuration",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "description": "Service type for web admin",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
          "default": "ClusterIP"
        },
        "port": {
          "type": "integer",
          "description": "Web admin HTTP port",
          "default": 80
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the web service"
        },
        "ipFamilyPolicy": {
          "type": ["string", "null"],
          "description": "Dual-stack ipFamilyPolicy (GR-058)",
          "enum": [null, "SingleStack", "PreferDualStack", "RequireDualStack"]
        },
        "ipFamilies": {
          "type": "array",
          "description": "Dual-stack ipFamilies (GR-058)",
          "items": { "type": "string", "enum": ["IPv4", "IPv6"] },
          "maxItems": 2
        }
      }
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration for the web admin interface",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ingress for the web admin interface",
          "default": false
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Ingress annotations"
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "description": "Ingress TLS configuration",
          "items": {
            "type": "object",
            "properties": {
              "hosts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "secretName": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "serviceAccount": {
      "type": "object",
      "description": "ServiceAccount configuration",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "description": "Create a dedicated ServiceAccount",
          "default": false
        },
        "name": {
          "type": "string",
          "description": "Name override (auto-generated if empty)",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the ServiceAccount"
        }
      }
    },
    "metrics": {
      "type": "object",
      "description": "Prometheus metrics via pihole-exporter sidecar",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Prometheus metrics via pihole-exporter sidecar",
          "default": false
        },
        "image": {
          "type": "object",
          "description": "pihole-exporter image configuration",
          "properties": {
            "repository": {
              "type": "string",
              "description": "pihole-exporter image repository",
              "default": "docker.io/ekofr/pihole-exporter"
            },
            "tag": {
              "type": "string",
              "description": "pihole-exporter image tag",
              "default": "v1.2.0"
            },
            "pullPolicy": {
              "type": "string",
              "description": "pihole-exporter pull policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "port": {
          "type": "integer",
          "description": "Port for the Prometheus metrics endpoint",
          "default": 9617
        },
        "serviceMonitor": {
          "type": "object",
          "description": "ServiceMonitor for Prometheus Operator",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Create a ServiceMonitor resource",
              "default": false
            },
            "interval": {
              "type": "string",
              "description": "Scrape interval",
              "default": "30s"
            },
            "labels": {
              "type": "object",
              "description": "Additional labels for the ServiceMonitor"
            }
          }
        }
      }
    },
    "unbound": {
      "type": "object",
      "description": "Unbound sidecar for recursive DNS resolution. When enabled, Pi-hole upstream DNS is automatically set to 127.0.0.1#5335.",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable Unbound sidecar for recursive DNS resolution",
          "default": false
        },
        "image": {
          "type": "object",
          "description": "Unbound image configuration",
          "properties": {
            "repository": {
              "type": "string",
              "description": "Unbound image repository",
              "default": "docker.io/mvance/unbound"
            },
            "tag": {
              "type": "string",
              "description": "Unbound image tag",
              "default": "1.22.0"
            },
            "pullPolicy": {
              "type": "string",
              "description": "Unbound pull policy",
              "enum": ["Always", "IfNotPresent", "Never"],
              "default": "IfNotPresent"
            }
          }
        },
        "port": {
          "type": "integer",
          "description": "Unbound listening port inside the pod",
          "default": 5335
        },
        "config": {
          "type": "string",
          "description": "Full unbound.conf override. When empty, a sensible default binding 127.0.0.1 at unbound.port is rendered.",
          "default": ""
        },
        "extraConfig": {
          "type": "string",
          "description": "Extra unbound directives appended inside the default server: section. Ignored when unbound.config is set.",
          "default": ""
        },
        "resources": {
          "type": "object",
          "description": "Resources for the Unbound sidecar"
        }
      }
    },
    "dhcp": {
      "type": "object",
      "description": "DHCP server configuration (requires hostNetwork or special network configuration)",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable DHCP server",
          "default": false
        },
        "hostNetwork": {
          "type": "boolean",
          "description": "Use host network for DHCP broadcasts",
          "default": false
        }
      }
    },
    "nodeSelector": {
      "type": "object",
      "description": "Node selector for pod scheduling"
    },
    "tolerations": {
      "type": "array",
      "description": "Tolerations for pod scheduling",
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "description": "Affinity rules for pod scheduling"
    },
    "topologySpreadConstraints": {
      "type": "array",
      "description": "Topology spread constraints",
      "items": {
        "type": "object"
      }
    },
    "priorityClassName": {
      "type": "string",
      "description": "Priority class name",
      "default": ""
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "description": "Grace period for shutdown (seconds)",
      "default": 30
    },
    "podLabels": {
      "type": "object",
      "description": "Additional labels for the pod"
    },
    "podAnnotations": {
      "type": "object",
      "description": "Additional annotations for the pod"
    },
    "extraVolumeMounts": {
      "type": "array",
      "description": "Additional volume mounts for the Pi-hole container",
      "items": {
        "type": "object"
      }
    },
    "extraVolumes": {
      "type": "array",
      "description": "Additional volumes for the pod",
      "items": {
        "type": "object"
      }
    },
    "extraManifests": {
      "type": "array",
      "description": "Extra Kubernetes manifests to deploy alongside the chart",
      "items": {
        "type": "object"
      }
    },
    "gateway": {
      "type": "object",
      "description": "Gateway API HTTPRoute configuration for the web UI.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "annotations": { "type": "object" },
        "parentRefs": { "type": "array", "items": { "type": "object" } },
        "hostnames": { "type": "array", "items": { "type": "string" } },
        "path": { "type": "string", "default": "/" },
        "pathType": { "type": "string", "enum": ["PathPrefix", "Exact", "RegularExpression"], "default": "PathPrefix" }
      }
    },
    "externalSecrets": {
      "type": "object",
      "description": "External Secrets Operator configuration.",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "apiVersion": { "type": "string", "default": "external-secrets.io/v1" },
        "refreshInterval": { "type": "string", "default": "0" },
        "secretStoreRef": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "kind": { "type": "string" }
          }
        },
        "target": {
          "type": "object",
          "properties": {
            "creationPolicy": { "type": "string" }
          }
        },
        "data": { "type": "array", "items": { "type": "object" } }
      }
